{
  "entities": {
    "Lead": {
      "title": "Lead",
      "description": "A contact request from a potential client.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the lead." },
        "email": { "type": "string", "format": "email", "description": "The email of the lead." },
        "message": { "type": "string", "description": "The message from the lead." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the lead was created." },
        "status": { "type": "string", "enum": ["new", "contacted", "closed"], "description": "The status of the lead." }
      },
      "required": ["name", "email", "message", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "A user of the application.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "client"] }
      },
      "required": ["uid", "email"]
    },
    "PortfolioItem": {
      "title": "Portfolio Item",
      "description": "An item in the portfolio.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "category": { "type": "string" },
        "image": { "type": "string", "description": "URL of the image." },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "category", "image", "createdAt"]
    }
  },
  "firestore": {
    "/leads/{leadId}": {
      "schema": "Lead",
      "description": "Collection of contact requests."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles."
    },
    "/portfolio/{itemId}": {
      "schema": "PortfolioItem",
      "description": "Collection of portfolio items."
    }
  }
}
